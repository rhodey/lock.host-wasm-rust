package local:app;

interface helpers-interface {
  poll: func(handle: s64) -> string;
  chat-completion: func(api-key: string, json: string) -> s64;
  address-from-seed: func(seed: string) -> string;
  get-balance: func(rpc: string, address: string) -> s64;
  transfer-from-seed: func(rpc: string, seed: string, destination: string, amount: s64) -> s64;
}

world helpers {
  export helpers-interface;
}

world app {
  import helpers-interface;
}
