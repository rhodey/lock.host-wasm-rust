package local:app;

interface helpers-interface {
  use wasi:io/streams@0.2.9.{input-stream};

  chat-completion: func(api-key: string, json: string) -> input-stream;
  get-balance: func(rpc: string, address: string) -> input-stream;
}

world helpers {
  export helpers-interface;
}

world app {
  import helpers-interface;
}
